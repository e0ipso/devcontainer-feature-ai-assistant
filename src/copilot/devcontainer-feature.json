{
  "id": "copilot",
  "version": "1.1.0",
  "name": "GitHub Copilot CLI",
  "description": "Installs the GitHub Copilot CLI into the dev container.",
  "options": {
    "updateOnPostStart": {
      "type": "boolean",
      "default": true,
      "description": "Run 'npm install -g @github/copilot' during the dev container postStart phase to update to the latest version."
    }
  },
  "containerEnv": {
    "PATH": "/usr/local/share/npm-global/bin:$PATH"
  },
  "postStartCommand": "if [ -x /usr/local/share/devcontainer-feature-ai-assistant/copilot/update.sh ]; then /usr/local/share/devcontainer-feature-ai-assistant/copilot/update.sh; fi",
  "installsAfter": [
    "ghcr.io/devcontainers/features/common-utils",
    "ghcr.io/devcontainers/features/node",
    "ghcr.io/devcontainers/features/github-cli"
  ]
}
