{
  "id": "cursor",
  "version": "1.1.0",
  "name": "Cursor CLI",
  "description": "Installs the Cursor CLI (agent) into the dev container.",
  "options": {
    "updateOnPostStart": {
      "type": "boolean",
      "default": true,
      "description": "Re-run the Cursor installer during the dev container postStart phase to update to the latest version."
    }
  },
  "containerEnv": {
    "PATH": "/usr/local/share/npm-global/bin:$PATH"
  },
  "postStartCommand": "if [ -x /usr/local/share/devcontainer-feature-ai-assistant/cursor/update.sh ]; then /usr/local/share/devcontainer-feature-ai-assistant/cursor/update.sh; fi",
  "installsAfter": [
    "ghcr.io/devcontainers/features/common-utils",
    "ghcr.io/devcontainers/features/node",
    "ghcr.io/devcontainers/features/github-cli"
  ]
}
